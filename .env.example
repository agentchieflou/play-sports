# Copy to .env and fill in values. See AGENTS.md > "Free-tier / local model slots".
# Not yet consumed by any code in this repo - env-var contract for future connectors.

# Local Ollama instance (no cost, works offline).
OLLAMA_HOST=http://localhost:11434

# Google AI Studio free tier (https://aistudio.google.com/apikey).
GEMINI_API_KEY=

# OpenRouter free-tier models (https://openrouter.ai/keys).
OPENROUTER_API_KEY=
